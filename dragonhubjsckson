-- LOADING PROGRESS
-- ═══════════════════════════════════════════════════════════
local function RunLoadProgress()
	if CFG.LOADING_TIME == 0 then
		local loadDone=false
		task.spawn(function()
			if not game:IsLoaded() then game.Loaded:Wait() end
			pcall(function() ContentProvider:PreloadAsync({BgImg}) end)
			loadDone=true
		end)
		local elapsed=0; local fakeMax=8
		while alive and not loadDone do
			local dt=RunService.Heartbeat:Wait(); elapsed=elapsed+dt
			local pct=math.clamp(elapsed/fakeMax,0,0.9)
			if BarFill and BarFill.Parent then Lin(BarFill,0.12,{Size=UDim2.fromScale(pct,1)}) end
			if PctLbl  and PctLbl.Parent  then PctLbl.Text=math.floor(pct*100).."%" end
		end
		if alive then
			if BarFill and BarFill.Parent then Lin(BarFill,0.5,{Size=UDim2.fromScale(1,1)}) end
			if PctLbl  and PctLbl.Parent  then PctLbl.Text="100%" end
		end
	else
		local total=math.max(CFG.LOADING_TIME,0.5)
		local start=tick(); local msgIdx=1; local lastMsg=start; local msgGap=total/#STATUSES
		while alive do
			local elapsed=tick()-start; local pct=math.clamp(elapsed/total,0,1)
			if BarFill and BarFill.Parent then Lin(BarFill,0.12,{Size=UDim2.fromScale(pct,1)}) end
			if PctLbl  and PctLbl.Parent  then PctLbl.Text=math.floor(pct*100).."%" end
			local lit=math.floor(pct*#EnergyOrbs)
			for idx, eo in ipairs(EnergyOrbs) do
				if eo and eo.Parent then Sine(eo,0.4,{BackgroundTransparency=idx<=lit and 0 or 0.85}) end
			end
			if tick()-lastMsg > msgGap then
				lastMsg=tick(); msgIdx=math.min(msgIdx+1,#STATUSES)
				SetStatus(STATUSES[msgIdx])
			end
			if pct >= 1 then break end
			task.wait(0.05)
		end
	end
end

