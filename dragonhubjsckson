-- ALIVE FLAG  +  SAFE HELPERS
-- ═══════════════════════════════════════════════════════════
local alive = true

local function New(class, props, parent)
	local inst = Instance.new(class)
	for k, v in pairs(props) do inst[k] = v end
	if parent then inst.Parent = parent end
	return inst
end

local function Tween(inst, t, style, dir, props)
	if not alive or not inst or not inst.Parent then return end
	local ok, tw = pcall(TweenService.Create, TweenService, inst,
		TweenInfo.new(t, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props)
	if ok and tw then tw:Play() return tw end
end

local function CloseTween(inst, t, style, dir, props)
	if not inst or not inst.Parent then return end
	local ok, tw = pcall(TweenService.Create, TweenService, inst,
		TweenInfo.new(t, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out), props)
	if ok and tw then tw:Play() return tw end
end

local function Sine(inst, t, props)
	return Tween(inst, t, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, props)
end
local function Lin(inst, t, props)
	return Tween(inst, t, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, props)
end

local function Loop(fn)
	task.spawn(function()
		while alive do fn() end
	end)
end

